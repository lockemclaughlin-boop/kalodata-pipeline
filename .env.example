# Copy this file to .env and fill it in. .env is gitignored — each machine
# keeps its own. On Mac/Linux:  cp .env.example .env

# REQUIRED — Google Gemini API key. Powers the Nano Banana restage step and
# the hook/caption/environment text generation (and the Veo API video path,
# if used). Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_key_here

# Optional: if you switch to Vertex AI instead of AI Studio
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# OPTIONAL — only shows an "expected account" hint in scripts/login_kalodata.py.
# Login is always done by hand in the popped browser; the password is never
# read or typed by the app. After login, the session lives in
# .auth/chrome-profile/. Safe to leave blank.
KALODATA_EMAIL=
KALODATA_PASSWORD=

# Where finished videos land. Absolute path. If blank, defaults to ./outputs
OUTPUT_DIR=

# Hard ceiling on a single run's estimated spend (USD). The app refuses to
# start a run whose estimate exceeds this. The Flow backend bills Google AI
# Ultra credits, not USD, so this mainly guards the Veo API path. At Veo 3.1
# Lite pricing (~$0.40/clip), $25 covers ~60 clips — adjust to taste.
MAX_RUN_COST_USD=25
